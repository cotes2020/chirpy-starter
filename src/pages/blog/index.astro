---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await Astro.glob('./*.md');
const sorted = posts
  .filter(p => !p.frontmatter.pin)
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---
<BaseLayout title="Blog">
  <h1>Blog</h1>
  <p class="subtitle">Shower thoughts, technical ramblings, and the occasional sassy observation.</p>

  <ul class="post-list">
    {sorted.map(post => {
      const { title, date, tags = [], categories = [] } = post.frontmatter;
      const formattedDate = new Date(date).toLocaleDateString('en-CA', {
        year: 'numeric', month: 'short', day: 'numeric'
      });
      return (
        <li class="post-card">
          <div class="post-meta">
            <time>{formattedDate}</time>
            {categories.length > 0 && <span class="cat">{categories[0]}</span>}
          </div>
          <a href={post.url} class="post-title">{title}</a>
          <div class="tags">
            {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .subtitle { color: var(--text-muted); margin-bottom: 2.5rem; }
  .post-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.5rem; }
  .post-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s;
  }
  .post-card:hover { border-color: var(--accent); }
  .post-meta { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.4rem; display: flex; gap: 0.75rem; }
  .cat { color: var(--accent); }
  .post-title { font-size: 1.1rem; font-weight: 600; color: var(--text); }
  .post-title:hover { color: var(--accent); text-decoration: none; }
  .tags { margin-top: 0.6rem; display: flex; flex-wrap: wrap; gap: 0.35rem; }
</style>
