---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="Phillip Bruno's personal portfolio and blog.">
  <section class="hero">
    <img src="/assets/img/favicons/favicon.svg" alt="Phillip Bruno" class="avatar" />
    <h1>Phillip Bruno</h1>
    <p class="tagline">A simple website with a bit about me, my work, and my occasional random thoughts.</p>
    <p class="description">My personal portfolio and blog chronicling the thrilling saga of my professional life — mostly a collection of shower thoughts and ramblings, sprinkled in with some sassy coffee critiques.</p>
    <div class="hero-links">
      <a href="/blog" class="btn">Read the Blog</a>
      <a href="/career" class="btn btn-secondary">View Career</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem;
  }
  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-bottom: 1rem;
    border: 3px solid var(--accent);
  }
  h1 { font-size: 2.5rem; margin: 0.5rem 0; }
  .tagline {
    font-size: 1.1rem;
    color: var(--accent);
    margin: 0.5rem 0;
  }
  .description {
    color: var(--text-muted);
    max-width: 600px;
    margin: 1rem auto 2rem;
  }
  .hero-links { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    background: var(--accent);
    color: var(--bg);
    padding: 0.6rem 1.4rem;
    border-radius: 6px;
    font-weight: 600;
    transition: opacity 0.2s;
    text-decoration: none;
  }
  .btn:hover { opacity: 0.85; text-decoration: none; }
  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }
</style>
